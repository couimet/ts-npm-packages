{
  "name": "ts-npm-packages",
  "private": true,
  "homepage": "https://github.com/couimet/ts-npm-packages#readme",
  "bugs": {
    "url": "https://github.com/couimet/ts-npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:couimet/ts-npm-packages.git"
  },
  "license": "MIT",
  "author": "Charles Ouimet <charles.ouimet@gmail.com>",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset:pre-alpha": "pnpm guard:not-main && changeset pre enter alpha",
    "changeset:pre-beta": "pnpm guard:not-main && changeset pre enter beta",
    "changeset:pre-exit": "pnpm guard:not-main && changeset pre exit",
    "changeset:version": "changeset version",
    "clean": "turbo run clean",
    "clean:all": "turbo run clean:all",
    "clean:deps": "turbo run clean:deps",
    "fix": "pnpm format:fix && pnpm lint:fix && pnpm lint:md:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "guard:not-main": "scripts/guard-not-main.sh",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint:md:fix": "markdownlint-cli2 --fix '**/*.md'",
    "lint:sh": "shellcheck **/*.sh",
    "prepare": "husky",
    "publish:verify": "scripts/publish-verify.sh",
    "release": "turbo run build && changeset publish",
    "test": "turbo run test",
    "test:scripts": "bats bats-tests/scripts/",
    "typecheck": "turbo run typecheck",
    "version:check-registry": "scripts/version-check-registry.sh",
    "version:list": "scripts/version-list.sh"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": [
      "pnpm exec eslint --fix",
      "pnpm exec prettier --write"
    ],
    "*.{json,md,yaml,yml}": "pnpm exec prettier --write",
    "*.{sh,bash}": [
      "shellcheck"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@couimet/eslint-config": "workspace:*",
    "bats": "^1.13.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "shellcheck": "^4.1.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.17",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed",
  "engines": {
    "node": ">=24"
  }
}
