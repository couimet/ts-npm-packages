{
  "name": "@couimet/logger-contract-testing",
  "version": "1.0.0",
  "description": "Zero-setup mock-logger factories for tests written against @couimet/logger-contract",
  "homepage": "https://github.com/couimet/ts-npm-packages/tree/main/packages/logger-contract-testing#readme",
  "bugs": {
    "url": "https://github.com/couimet/ts-npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:couimet/ts-npm-packages.git",
    "directory": "packages/logger-contract-testing"
  },
  "license": "MIT",
  "author": "Charles Ouimet <charles.ouimet@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "clean:all": "pnpm clean && rm -rf node_modules .eslintcache *.log",
    "clean:deps": "rm -rf node_modules",
    "format": "prettier --check .",
    "lint": "eslint .",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "devDependencies": {
    "@couimet/eslint-config": "workspace:*",
    "@couimet/logger-contract": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-packagejson": "^3.0.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@couimet/logger-contract": "workspace:*",
    "jest": "^29.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
