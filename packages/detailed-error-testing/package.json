{
  "name": "@couimet/detailed-error-testing",
  "version": "0.1.1-alpha.0",
  "description": "Custom Jest matchers for testing code that throws or returns DetailedError",
  "homepage": "https://github.com/couimet/ts-npm-packages/tree/main/packages/detailed-error-testing#readme",
  "bugs": {
    "url": "https://github.com/couimet/ts-npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:couimet/ts-npm-packages.git",
    "directory": "packages/detailed-error-testing"
  },
  "license": "MIT",
  "author": "Charles Ouimet <charles.ouimet@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./setup": {
      "types": "./dist/setup.d.ts",
      "import": "./dist/setup.mjs",
      "require": "./dist/setup.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "clean:all": "pnpm clean && rm -rf node_modules .eslintcache *.log",
    "clean:deps": "rm -rf node_modules",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "devDependencies": {
    "@couimet/detailed-error": "workspace:*",
    "@couimet/eslint-config": "workspace:*",
    "@jest/expect": ">=30.0.0",
    "@jest/globals": ">=30.0.0",
    "@types/jest": ">=29.5.14",
    "@types/node": ">=24.13.2",
    "@typescript-eslint/eslint-plugin": ">=8.61.0",
    "@typescript-eslint/parser": ">=8.61.0",
    "eslint": ">=10.4.1",
    "eslint-config-prettier": ">=10.1.8",
    "eslint-plugin-prettier": ">=5.5.6",
    "eslint-plugin-simple-import-sort": ">=13.0.0",
    "eslint-plugin-unused-imports": ">=4.4.1",
    "globals": ">=16.5.0",
    "jest": ">=29.7.0",
    "prettier": ">=3.8.4",
    "prettier-plugin-packagejson": ">=3.0.2",
    "ts-jest": ">=29.4.11",
    "tsup": ">=8.5.1",
    "typescript": ">=6.0.3"
  },
  "peerDependencies": {
    "@couimet/detailed-error": "workspace:*",
    "@jest/expect": ">=30.0.0",
    "@jest/globals": ">=30.0.0",
    "jest": ">=29.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
