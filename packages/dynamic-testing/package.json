{
  "name": "@couimet/dynamic-testing",
  "version": "0.3.0",
  "description": "Dynamic testing utilities with seeded randomness for TypeScript tests",
  "homepage": "https://github.com/couimet/ts-npm-packages/tree/main/packages/dynamic-testing#readme",
  "bugs": {
    "url": "https://github.com/couimet/ts-npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:couimet/ts-npm-packages.git",
    "directory": "packages/dynamic-testing"
  },
  "license": "MIT",
  "author": "Charles Ouimet <charles.ouimet@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "clean:all": "pnpm clean && rm -rf node_modules .eslintcache *.log",
    "clean:deps": "rm -rf node_modules",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "dependencies": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@couimet/eslint-config": "workspace:*",
    "@types/jest": ">=29.5.14",
    "@types/node": ">=24.13.2",
    "decimal.js": ">=10.4.3",
    "eslint": ">=10.4.1",
    "jest": ">=29.7.0",
    "prettier": ">=3.8.4",
    "ts-jest": ">=29.4.11",
    "tsup": ">=8.5.1",
    "typescript": ">=6.0.3"
  },
  "peerDependencies": {
    "decimal.js": ">=10.0.0"
  },
  "peerDependenciesMeta": {
    "decimal.js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
