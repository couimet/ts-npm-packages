{
  "name": "@couimet/logger-contract-adapters",
  "version": "0.2.0-alpha.0",
  "description": "Logger adapters that bridge @couimet/logger-contract with popular logging libraries",
  "homepage": "https://github.com/couimet/ts-npm-packages/tree/main/packages/logger-contract-adapters#readme",
  "bugs": {
    "url": "https://github.com/couimet/ts-npm-packages/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:couimet/ts-npm-packages.git",
    "directory": "packages/logger-contract-adapters"
  },
  "license": "MIT",
  "author": "Charles Ouimet <charles.ouimet@gmail.com>",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage *.tsbuildinfo",
    "clean:all": "pnpm clean && rm -rf node_modules .eslintcache *.log",
    "clean:deps": "rm -rf node_modules",
    "test": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "prettier": "@couimet/eslint-config/prettier",
  "dependencies": {
    "@couimet/logger-contract": "workspace:*"
  },
  "devDependencies": {
    "@couimet/dynamic-testing": "workspace:*",
    "@couimet/eslint-config": "workspace:*",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "eslint": "^10.4.1",
    "jest": "^29.7.0",
    "log4js": ">=6.0.0",
    "pino": ">=9.0.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "winston": ">=3.0.0"
  },
  "peerDependencies": {
    "log4js": ">=6.0.0",
    "pino": ">=9.0.0",
    "winston": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "log4js": {
      "optional": true
    },
    "pino": {
      "optional": true
    },
    "winston": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
